{
  "version": 3,
  "core": {
    "enabled": true,
    "logLevel": "info",
    "logRetentionFiles": 7,
    "trackSeenApps": true
  },
  "applications": [
    {
      "id": "dcs",
      "name": "DCS",
      "enabled": true,
      "match": {
        "exe": "DCS.exe"
      }
    }
  ],
  "modules": {
    "depthxr": {
      "enabled": true,
      "defaults": {
        "stereoBoost": 1.1,
        "convergence": 0.0,
        "depthAnchor": false
      },
      "bindings": {
        "toggleEnabled": {
          "type": "none"
        }
      },
      "profiles": [
        {
          "name": "DCS",
          "enabled": true,
          "applicationIds": [
            "dcs"
          ],
          "settings": {
            "stereoBoost": 1.12,
            "convergence": 0.01,
            "depthAnchor": true
          }
        }
      ]
    },
    "pivotxr": {
      "enabled": false,
      "defaults": {
        "smoothing": 0.2,
        "activationRampSeconds": 0.35,
        "rotationMultiplier": 1.5,
        "deadzoneDegrees": 8.0,
        "maxExtraYawDegrees": 25.0,
        "pitchRotationMultiplier": 1.0,
        "pitchDeadzoneDegrees": 12.0,
        "maxExtraPitchDegrees": 20.0
      },
      "profiles": [
        {
          "name": "DCS",
          "enabled": true,
          "applicationIds": [
            "dcs"
          ],
          "activationMode": "toggle",
          "activationBinding": {
            "type": "none"
          },
          "settings": {
            "smoothing": 0.2,
            "activationRampSeconds": 0.35,
            "rotationMultiplier": 1.7,
            "deadzoneDegrees": 10.0,
            "maxExtraYawDegrees": 60.0,
            "pitchRotationMultiplier": 1.2,
            "pitchDeadzoneDegrees": 15.0,
            "maxExtraPitchDegrees": 45.0
          }
        }
      ]
    },
    "quadviews": {
      "enabled": false,
      "defaults": {
        "trackingMode": "eye",
        "focusHorizontalSizePercent": 40.0,
        "focusVerticalSizePercent": 40.0,
        "focusScale": 1.1,
        "peripheralScale": 0.35,
        "foveateSharpness": 50.0,
        "transitionThicknessPercent": 25.0,
        "horizontalOffsetDegrees": 0.0,
        "verticalOffsetDegrees": 0.0,
        "gazeSmoothing": 0.15,
        "gazeDeadzoneDegrees": 1.5
      },
      "profiles": [
        {
          "name": "DCS",
          "enabled": true,
          "applicationIds": [
            "dcs"
          ],
          "settings": {
            "trackingMode": "eye",
            "focusHorizontalSizePercent": 32.0,
            "focusVerticalSizePercent": 28.0,
            "focusScale": 1.15,
            "peripheralScale": 0.4,
            "foveateSharpness": 50.0,
            "transitionThicknessPercent": 25.0,
            "horizontalOffsetDegrees": 0.0,
            "verticalOffsetDegrees": 0.0,
            "gazeSmoothing": 0.12,
            "gazeDeadzoneDegrees": 1.0
          }
        }
      ]
    }
  }
}
