{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DepthXR",
  "version": "0.1.0",
  "identifier": "local.depthxr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DepthXR",
        "width": 1280,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
