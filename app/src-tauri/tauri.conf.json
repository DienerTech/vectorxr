{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VectorXR",
  "version": "0.4.0",
  "identifier": "local.vectorxr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/vectorxr-layer/XR_APILAYER_DIENERTECH_VECTORXR.dll": "vectorxr-layer/XR_APILAYER_DIENERTECH_VECTORXR.dll",
      "resources/vectorxr-layer/XR_APILAYER_DIENERTECH_VECTORXR.json": "vectorxr-layer/XR_APILAYER_DIENERTECH_VECTORXR.json"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/nsis-hooks.nsh"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VectorXR",
        "width": 1280,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
