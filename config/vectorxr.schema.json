{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vectorxr.local/schema/vectorxr.schema.json",
  "title": "VectorXR Settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "core",
    "applications",
    "modules"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 3
    },
    "core": {
      "$ref": "#/$defs/core"
    },
    "applications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/application"
      }
    },
    "modules": {
      "$ref": "#/$defs/modules"
    }
  },
  "$defs": {
    "logLevel": {
      "type": "string",
      "enum": [
        "off",
        "error",
        "info",
        "debug"
      ]
    },
    "activationMode": {
      "type": "string",
      "enum": [
        "toggle",
        "hold"
      ]
    },
    "keyboardKey": {
      "type": "string",
      "pattern": "^(Ctrl|Alt|Shift|F([1-9]|1[0-2])|[A-Z]|[0-9]|Space)$"
    },
    "inputBinding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "none"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "chord"
          ],
          "properties": {
            "type": {
              "const": "keyboard"
            },
            "chord": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/keyboardKey"
              },
              "uniqueItems": true
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "deviceGuid",
            "inputPath"
          ],
          "properties": {
            "type": {
              "const": "device"
            },
            "deviceGuid": {
              "type": "string",
              "minLength": 1
            },
            "inputPath": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "profileMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exe"
      ],
      "properties": {
        "exe": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "enabled",
        "match"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "match": {
          "$ref": "#/$defs/profileMatch"
        }
      }
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "logLevel",
        "logRetentionFiles"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "logLevel": {
          "$ref": "#/$defs/logLevel"
        },
        "logRetentionFiles": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        }
      }
    },
    "depthxrSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stereoBoostEnabled",
        "convergenceEnabled",
        "stereoBoost",
        "convergence"
      ],
      "properties": {
        "stereoBoostEnabled": {
          "type": "boolean"
        },
        "convergenceEnabled": {
          "type": "boolean"
        },
        "stereoBoost": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.0
        },
        "convergence": {
          "type": "number",
          "minimum": -0.5,
          "maximum": 0.5
        }
      }
    },
    "depthxrProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "enabled",
        "applicationIds",
        "settings"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "applicationIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "settings": {
          "$ref": "#/$defs/depthxrSettings"
        }
      }
    },
    "depthxrBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toggleEnabled"
      ],
      "properties": {
        "toggleEnabled": {
          "$ref": "#/$defs/inputBinding"
        }
      }
    },
    "depthxrModule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "defaults",
        "bindings",
        "profiles"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaults": {
          "$ref": "#/$defs/depthxrSettings"
        },
        "bindings": {
          "$ref": "#/$defs/depthxrBindings"
        },
        "profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/depthxrProfile"
          }
        }
      }
    },
    "pivotxrSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rotationMultiplier",
        "smoothing",
        "deadzoneDegrees",
        "maxExtraYawDegrees",
        "pitchRotationMultiplier",
        "pitchSmoothing",
        "pitchDeadzoneDegrees",
        "maxExtraPitchDegrees"
      ],
      "properties": {
        "rotationMultiplier": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 3.0
        },
        "smoothing": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "deadzoneDegrees": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 45.0
        },
        "maxExtraYawDegrees": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 180.0
        },
        "pitchRotationMultiplier": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 3.0
        },
        "pitchSmoothing": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "pitchDeadzoneDegrees": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 45.0
        },
        "maxExtraPitchDegrees": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 180.0
        }
      }
    },
    "pivotxrProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "enabled",
        "applicationIds",
        "activationMode",
        "activationBinding",
        "settings"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "applicationIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        },
        "activationMode": {
          "$ref": "#/$defs/activationMode"
        },
        "activationBinding": {
          "$ref": "#/$defs/inputBinding"
        },
        "settings": {
          "$ref": "#/$defs/pivotxrSettings"
        }
      }
    },
    "pivotxrModule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "defaults",
        "profiles"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaults": {
          "$ref": "#/$defs/pivotxrSettings"
        },
        "profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pivotxrProfile"
          }
        }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "depthxr",
        "pivotxr"
      ],
      "properties": {
        "depthxr": {
          "$ref": "#/$defs/depthxrModule"
        },
        "pivotxr": {
          "$ref": "#/$defs/pivotxrModule"
        }
      }
    }
  }
}
